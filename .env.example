# CobolShift Environment Configuration
# Copy this to .env and fill in your values

# ── Tool Database (CobolShift's own state DB) ──────────────────────────────
DATABASE_URL=postgresql+psycopg://cobolshift:secret@localhost:5432/cobolshift
DATABASE_POOL_SIZE=10

# ── Redis (Celery broker + result backend) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-string
FERNET_KEY=change-me-to-a-fernet-key-from-cryptography

# ── API settings ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── CDC / Kafka (optional, only needed for CDC mode) ──────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
DEBEZIUM_CONNECT_URL=http://localhost:8083
